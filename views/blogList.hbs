{{#each blogs}}
<article style="margin-bottom:40px">

  {{#if content}}
    <section>
      {{{content}}}
    </section>
  {{/if}}

  {{#if tags.length}}
    <p>
      <strong>Tags:</strong>
      {{#each tags}}
        <span>#{{this}}</span>
      {{/each}}
    </p>
  {{/if}}

  <p>
    <small>
      Published: {{publishedAt}} <br />
      Updated: {{updatedAt}}
    </small>
  </p>

</article>
{{/each}}
